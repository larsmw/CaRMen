<table class="table">
  <thead>
    <tr>
      <th>First Name</th>
      <th>Last Name</th>
      <th>Phone</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {% for customer in pagination %}
      <tr>
        <td><a href="{{ path('app_customer_show', {'id': customer.id}) }}">{{ customer.firstName }}</a></td>
        <td>{{ customer.lastName }}</td>
        <td>{{ customer.phone }}</td>
        <td>
          <form method="post" action="{{ path('app_customer_delete', {'id': customer.id}) }}"
                onsubmit="return confirm('Delete {{ customer.firstName }} {{ customer.lastName }}?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ customer.id) }}">
            <button class="btn btn-danger">Delete</button>
          </form>
        </td>
      </tr>
    {% else %}
      <tr>
        <td colspan="4">No customers found.</td>
      </tr>
    {% endfor %}
  </tbody>
</table>
{{ knp_pagination_render(pagination) }}
